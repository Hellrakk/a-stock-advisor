                        return plan
            except:
                pass
        
        if REBALANCE_AVAILABLE and stock_data is not None:
            return self._generate_rebalance_plan(stock_data)
        
        return None
    
    def _generate_rebalance_plan(self, stock_data):
        """生成换仓计划"""
        try:
            portfolio_tracker = PortfolioTracker()
            
            if not portfolio_tracker.positions:
                logger.info("当前无持仓，无需生成换仓计划")
                return None
            
            rebalance_strategy = RebalanceStrategy()
            
            alpha_scores = pd.Series()
            for stock_code, position in portfolio_tracker.positions.items():
                alpha_scores[stock_code] = position.alpha_score if position.alpha_score > 0 else 0.5
            
            plan = rebalance_strategy.evaluate_rebalance(
                portfolio_tracker=portfolio_tracker,
                stock_data=stock_data,
                alpha_scores=alpha_scores,
                market_volatility=0.15,
                market_trend='neutral'
            )
            
            plan_dict = {
                'date': plan.date,
                'actions': plan.actions,
                'summary': plan.summary
            }
            
            os.makedirs('data', exist_ok=True)
            with open('data/rebalance_plan.json', 'w', encoding='utf-8') as f:
                json.dump(plan_dict, f, ensure_ascii=False, indent=2, default=str)
            
            logger.info(f"换仓计划已生成: {len(plan.actions)}个操作")
            return plan_dict
            
        except Exception as e:
            logger.error(f"生成换仓计划失败: {e}", exc_info=True)
            return None
    
    def _generate_executable_trade_list(self, selection, stock_data=None, total_capital=1000000):
        """
        生成可执行交易清单
        
        Args:
            selection: 选股结果
            stock_data: 股票数据
            total_capital: 总资金
            
        Returns:
            交易清单文本
        """
        if not selection or 'selected_stocks' not in selection:
            return None
        
        selected_stocks = selection['selected_stocks']
        if not selected_stocks:
            return None
        
        lines = []
        lines.append('序号 | 股票名称 | 股票代码 | 方向 | 目标权重 | 计划金额(100万) | 价格区间 | 买入时间')
        lines.append('─' * 80)
        
        total_weight = 0
        total_amount = 0
        
        for idx, stock in enumerate(selected_stocks[:10], 1):
            code = str(stock.get('code', stock.get('stock_code', 'N/A')))
            name = stock.get('name', stock.get('stock_name', 'N/A'))
            
            # 获取当前价格（如果有数据）
            current_price = 0
            price_low = 0
            price_high = 0
            
            if stock_data is not None and len(stock_data) > 0:
                # 优先通过股票名称匹配
                stock_info = stock_data[stock_data['stock_name'] == name]
                if len(stock_info) > 0:
                    current_price = stock_info['close'].iloc[-1]
                    # 价格区间：开盘价±2%（简化为当前价±2%）
                    price_low = current_price * 0.98
                    price_high = current_price * 1.02
                else:
                    # 尝试通过股票代码匹配
                    stock_info = None
                    # 直接匹配
                    stock_info = stock_data[stock_data['stock_code'] == code]
                    if len(stock_info) == 0:
                        # 尝试带前缀的格式
                        for prefix in ['sh', 'sz', 'bj']:
                            prefixed_code = f'{prefix}{code}'
                            stock_info = stock_data[stock_data['stock_code'] == prefixed_code]
                            if len(stock_info) > 0:
                                break
                    if len(stock_info) > 0:
                        current_price = stock_info['close'].iloc[-1]
                        # 价格区间：开盘价±2%（简化为当前价±2%）
                        price_low = current_price * 0.98
                        price_high = current_price * 1.02
            
            # 目标权重（等权重，10%每只）
            target_weight = 10.0
            planned_amount = int(total_capital * target_weight / 100)
            
            direction = '买入'  # 默认买入
            
            # 格式化股票代码，确保显示正确
            display_code = code.zfill(6) if len(code) < 6 else code
            
            lines.append(f'{idx} | {name} | {display_code} | {direction} | {target_weight}% | {planned_amount:,}元 | {price_low:.2f}-{price_high:.2f}元 | 9:30-10:00')
            
            total_weight += target_weight
            total_amount += planned_amount
        
        lines.append('─' * 80)
        lines.append(f'合计 | - | - | - | {total_weight}% | {total_amount:,}元 | - | -')
        lines.append('')
        
        return '\n'.join(lines)
    
