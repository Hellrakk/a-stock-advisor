# A股投资顾问系统 - 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# ===================
# 数据源 API 配置
# ===================

# Tushare 数据源 Token
# 获取地址: https://tushare.pro/register
TUSHARE_TOKEN=your_tushare_token_here

# 智兔数服 API Token
# 获取地址: https://www.zhituapi.com/
ZHITU_TOKEN=your_zhitu_token_here

# ===================
# 飞书推送配置
# ===================

# 飞书机器人 Webhook URL
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your_hook_id

# 飞书机器人签名密钥（如果启用了签名验证）
FEISHU_SECRET=your_feishu_secret_here

# ===================
# 其他配置
# ===================

# 日志级别 (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# 数据存储路径
DATA_DIR=./data
