<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.openclaw.healthcheck</string>

    <key>ProgramArguments</key>
    <array>
        <string>/opt/homebrew/bin/python3</string>
        <string>scripts/health_check.py</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/variya/.openclaw/workspace/projects/a-stock-advisor</string>

    <key>StandardOutPath</key>
    <string>/Users/variya/.openclaw/workspace/projects/a-stock-advisor/logs/health_check.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/variya/.openclaw/workspace/projects/a-stock-advisor/logs/health_check_error.log</string>

    <key>StartCalendarInterval</key>
    <array>
        <dict>
            <key>Hour</key>
            <integer>3</integer>
            <key>Minute</key>
            <integer>0</integer>
        </dict>
    </array>

    <key>WakeFromSleep</key>
    <true/>
</dict>
</plist>
